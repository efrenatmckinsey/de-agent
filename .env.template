# =============================================================================
# hydra-ingest — Environment Variables Template
# =============================================================================
# Copy to .env and fill in real values. NEVER commit .env to version control.
#   cp .env.template .env
# =============================================================================

# --- API Keys (optional for public endpoints, improves rate limits) ----------
USDA_API_KEY=
CENSUS_API_KEY=

# --- MinIO / S3 (local development) -----------------------------------------
MINIO_ROOT_USER=hydra
MINIO_ROOT_PASSWORD=

# --- AWS (production / staging) ----------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# --- Kafka / MSK -------------------------------------------------------------
# Local: no config needed (docker-compose exposes localhost:9092)
# AWS MSK: set bootstrap servers here
HYDRA_MSK_BOOTSTRAP_SERVERS=

# --- Observability -----------------------------------------------------------
# OpenTelemetry collector endpoint (default: http://localhost:4317)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- Platform ----------------------------------------------------------------
# Override the platform environment (dev | staging | prod)
HYDRA_ENV=dev

# Contact email used in NOAA API User-Agent header (required by NOAA TOS)
HYDRA_CONTACT_EMAIL=your-email@your-org.com
